/*
 * lzss.c
 * Streaming LZSS decompression
 * Reads compressed chunks from UART → decompresses → writes to flash
 */
#include "lzss.h"
#include "flash_if.h"
#include <string.h>

/* ================= DEFINES ================= */
#define LZSS_MIN_MATCH    3
#define LZSS_WINDOW_SIZE  256
#define LZSS_OUT_BUF      128   /* must be multiple of 4 for flash write */

/* ================= CHUNK READER STATE ================= */
static uint8_t  chunk_buf[MAX_CHUNK];
static uint16_t chunk_len = 0;
static uint16_t chunk_pos = 0;

/* ================= READ 1 BYTE FROM CHUNK STREAM ================= */
static int8_t Read_Byte(UART_HandleTypeDef *huart, uint8_t *out)
{
    while (chunk_pos >= chunk_len)
    {
        if (chunk_len > 0)
            Boot_SendAck(huart);

        uint8_t  size_buf[2];
        UART_ReadExact(huart, size_buf, 2);
        uint16_t size = (uint16_t)size_buf[0] | ((uint16_t)size_buf[1] << 8);

        if (size == END_MARKER)
        {
            Boot_SendAck(huart);
            return -1;
        }

        if (size > MAX_CHUNK)
        {
            Boot_SendErr(huart);
            return -2;
        }

        Boot_SendAck(huart);
        UART_ReadExact(huart, chunk_buf, size);
        chunk_len = size;
        chunk_pos = 0;
    }

    *out = chunk_buf[chunk_pos++];
    return 0;
}
/* ================= STREAMING DECOMPRESS TO FLASH ================= */
uint8_t LZSS_DecompressToFlash(UART_HandleTypeDef *huart,
                                uint32_t            original_size,
                                uint32_t            flash_address)
{
    uint8_t  window[LZSS_WINDOW_SIZE];
    uint8_t  out_buf[LZSS_OUT_BUF];
    uint8_t  bit_buf = 0;
    uint8_t  bit_pos = 0;
    uint32_t win_pos = 0;
    uint32_t out_pos = 0;
    uint32_t total   = 0;
    uint8_t  rx_byte;
    int8_t   ret;

    /* Reset state */
    chunk_len = 0;
    chunk_pos = 0;
    memset(window,  0x00, LZSS_WINDOW_SIZE);  /* must match Python */
    memset(out_buf, 0x00, LZSS_OUT_BUF);

    while (total < original_size)
    {
        /* Refill bit buffer */
    	if (bit_pos == 0)
    	{
    	    ret = Read_Byte(huart, &bit_buf);
    	    if (ret == -2) return 0;
    	    if (ret == -1) break;    // END marker → exit loop, flush remaining
    	    bit_pos = 8;
    	}

        /* Read 1 flag bit MSB first */
        uint8_t flag = (bit_buf >> 7) & 1;
        bit_buf      = (bit_buf << 1) & 0xFF;
        bit_pos--;

        if (flag == 0)
        {
            /* LITERAL */
            ret = Read_Byte(huart, &rx_byte);
            if (ret == -1) break;
            if (ret == -2) return 0;

            window[win_pos]    = rx_byte;
            out_buf[out_pos++] = rx_byte;
            win_pos            = (win_pos + 1) % LZSS_WINDOW_SIZE;
            total++;

            /* Flush when full */
            if (out_pos == LZSS_OUT_BUF)
            {
                if (Flash_Write(flash_address, out_buf, LZSS_OUT_BUF) != FLASH_OK)
                    {
                	uint8_t debug = 0xAA;  /* special byte — means Flash_Write failed */
                    HAL_UART_Transmit(huart, &debug, 1, HAL_MAX_DELAY);
                    return 0;
                    }

                flash_address += LZSS_OUT_BUF;
                out_pos        = 0;
                memset(out_buf, 0x00, LZSS_OUT_BUF);
            }
        }
        else
        {
            /* BACK-REFERENCE */
            uint8_t offset_val, length_val;

            ret = Read_Byte(huart, &offset_val);
            if (ret == -1) break;
            if (ret == -2) return 0;

            ret = Read_Byte(huart, &length_val);
            if (ret == -1) break;
            if (ret == -2) return 0;

            uint32_t offset = (uint32_t)offset_val + 1;
            uint32_t length = (uint32_t)length_val + LZSS_MIN_MATCH;

            for (uint32_t k = 0; k < length && total < original_size; k++)
            {
                uint32_t src_pos   = (win_pos - offset + LZSS_WINDOW_SIZE)
                                      % LZSS_WINDOW_SIZE;
                rx_byte            = window[src_pos];
                window[win_pos]    = rx_byte;
                out_buf[out_pos++] = rx_byte;
                win_pos            = (win_pos + 1) % LZSS_WINDOW_SIZE;
                total++;

                /* Flush when full */
                if (out_pos == LZSS_OUT_BUF)
                {
                    if (Flash_Write(flash_address, out_buf, LZSS_OUT_BUF) != FLASH_OK)
                    {
                	uint8_t debug = 0xAA;  /* special byte — means Flash_Write failed */
                    HAL_UART_Transmit(huart, &debug, 1, HAL_MAX_DELAY);
                    return 0;
                    }
                    flash_address += LZSS_OUT_BUF;
                    out_pos        = 0;
                    memset(out_buf, 0x00, LZSS_OUT_BUF);
                }
            }
        }
    }

    /* Flush remaining bytes — pad to 4-byte boundary with 0xFF */
    if (out_pos > 0)
    {
        uint32_t aligned = (out_pos + 3U) & ~3U;
        /* Pad remaining bytes with 0xFF (erased flash value) */
        for (uint32_t p = out_pos; p < aligned; p++)
            out_buf[p] = 0xFF;
        if (Flash_Write(flash_address, out_buf, aligned) != FLASH_OK)
        {
            uint8_t debug = 0xBB;  /* special byte — means final flush failed */
            HAL_UART_Transmit(huart, &debug, 1, HAL_MAX_DELAY);
            return 0;
        }
    }

    return 1;
}
