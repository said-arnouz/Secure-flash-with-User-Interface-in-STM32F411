#include "lzss.h"
#include "flash_if.h"

/* ================= DEFINES ================= */
#define LZSS_MIN_MATCH    3
#define LZSS_WINDOW_SIZE  256
#define LZSS_OUT_BUF      128

/* ================= CHUNK READER STATE ================= */
/* Holds the current compressed chunk being consumed */
static uint8_t  chunk_buf[MAX_CHUNK];
static uint16_t chunk_len = 0;
static uint16_t chunk_pos = 0;

/* Read 1 byte from current chunk — fetch next chunk from UART if needed */
static int8_t Read_Byte(UART_HandleTypeDef *huart, uint8_t *out)
{
    while (chunk_pos >= chunk_len)
    {
        /* Current chunk exhausted — fetch next one */
        uint8_t size_buf[2];
        UART_ReadExact(huart, size_buf, 2);
        uint16_t size = size_buf[0] | (size_buf[1] << 8);

        /* END marker → no more data */
        if (size == END_MARKER)
        {
            Boot_SendAck(huart);
            return -1;   /* signal: stream finished */
        }

        if (size > MAX_CHUNK)
        {
            Boot_SendErr(huart);
            return -2;   /* signal: error */
        }

        Boot_SendAck(huart);
        UART_ReadExact(huart, chunk_buf, size);
        Boot_SendAck(huart);

        chunk_len = size;
        chunk_pos = 0;
    }

    *out = chunk_buf[chunk_pos++];
    return 0;   /* success */
}

/* ================= STREAMING DECOMPRESS ================= */
uint8_t LZSS_DecompressToFlash(UART_HandleTypeDef *huart,
                                uint32_t            original_size,
                                uint32_t            flash_address)
{
    uint8_t  window[LZSS_WINDOW_SIZE];
    uint8_t  out_buf[LZSS_OUT_BUF];
    uint8_t  bit_buf  = 0;
    uint8_t  bit_pos  = 0;
    uint32_t win_pos  = 0;
    uint32_t out_pos  = 0;
    uint32_t total    = 0;
    uint8_t  rx_byte;
    int8_t   ret;

    /* Reset chunk reader state */
    chunk_len = 0;
    chunk_pos = 0;
    memset(window,  0x00, LZSS_WINDOW_SIZE);
    memset(out_buf, 0x00, LZSS_OUT_BUF);

    while (total < original_size)
    {
        /* --- Refill bit buffer --- */
        if (bit_pos == 0)
        {
            ret = Read_Byte(huart, &bit_buf);
            if (ret == -1) break;    /* END marker received */
            if (ret == -2) return 0; /* error              */
            bit_pos = 8;
        }

        /* --- Read 1 flag bit MSB first --- */
        uint8_t flag = (bit_buf >> 7) & 1;
        bit_buf      = (bit_buf << 1) & 0xFF;
        bit_pos--;

        if (flag == 0)
        {
            /* ---- LITERAL ---- */
            ret = Read_Byte(huart, &rx_byte);
            if (ret == -1) break;
            if (ret == -2) return 0;

            window[win_pos]    = rx_byte;
            out_buf[out_pos++] = rx_byte;
            win_pos            = (win_pos + 1) % LZSS_WINDOW_SIZE;
            total++;
        }
        else
        {
            /* ---- BACK-REFERENCE ---- */
            uint8_t offset_val, length_val;

            ret = Read_Byte(huart, &offset_val);
            if (ret == -1) break;
            if (ret == -2) return 0;

            ret = Read_Byte(huart, &length_val);
            if (ret == -1) break;
            if (ret == -2) return 0;

            uint32_t offset = (uint32_t)offset_val + 1;
            uint32_t length = (uint32_t)length_val + LZSS_MIN_MATCH;

            for (uint32_t k = 0; k < length && total < original_size; k++)
            {
                uint32_t src_pos   = (win_pos - offset + LZSS_WINDOW_SIZE)
                                      % LZSS_WINDOW_SIZE;
                rx_byte            = window[src_pos];
                window[win_pos]    = rx_byte;
                out_buf[out_pos++] = rx_byte;
                win_pos            = (win_pos + 1) % LZSS_WINDOW_SIZE;
                total++;

                /* Flush out_buf to flash when full */
                if (out_pos == LZSS_OUT_BUF)
                {
                    if (Flash_Write(flash_address, out_buf, LZSS_OUT_BUF) != FLASH_OK)
                        return 0;
                    flash_address += LZSS_OUT_BUF;
                    out_pos        = 0;
                    memset(out_buf, 0xFF, LZSS_OUT_BUF);
                }
            }
            continue;
        }

        /* Flush out_buf to flash when full (literal path) */
        if (out_pos == LZSS_OUT_BUF)
        {
            if (Flash_Write(flash_address, out_buf, LZSS_OUT_BUF) != FLASH_OK)
                return 0;
            flash_address += LZSS_OUT_BUF;
            out_pos        = 0;
            memset(out_buf, 0xFF, LZSS_OUT_BUF);
        }
    }

    /* Flush remaining bytes */
    if (out_pos > 0)
    {
        uint32_t aligned = (out_pos + 3U) & ~3U;
        if (Flash_Write(flash_address, out_buf, aligned) != FLASH_OK)
            return 0;
    }

    return 1;
}
