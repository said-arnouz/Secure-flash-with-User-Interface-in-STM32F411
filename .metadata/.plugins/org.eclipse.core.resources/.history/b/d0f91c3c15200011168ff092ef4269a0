#include "lzss.h"
#include "flash_if.h"

/* ================= DEFINES ================= */
#define LZSS_MIN_MATCH    3
#define LZSS_WINDOW_SIZE  256
#define LZSS_OUT_BUF      128

/* ================= GLOBALS ================= */
static const uint8_t ACK_BYTE = BOOT_ACK;

/* ================= STREAMING DECOMPRESS ================= */
uint8_t LZSS_DecompressToFlash(UART_HandleTypeDef *huart,
                                uint32_t            original_size,
                                uint32_t            flash_address)
{
    uint8_t  window[LZSS_WINDOW_SIZE];  /* 256B sliding window           */
    uint8_t  out_buf[LZSS_OUT_BUF];     /* 128B output chunk for flash   */
    uint8_t  bit_buf  = 0;              /* current byte of flag bits     */
    uint8_t  bit_pos  = 0;              /* bits left in bit_buf          */
    uint32_t win_pos  = 0;              /* current position in window    */
    uint32_t out_pos  = 0;              /* bytes written to out_buf      */
    uint32_t total    = 0;              /* total decompressed bytes      */

    /* chunk feeding state */
    uint8_t  chunk_buf[MAX_CHUNK];      /* current chunk data            */
    uint32_t chunk_pos  = 0;            /* read position in chunk_buf    */
    uint32_t chunk_len  = 0;            /* valid bytes in chunk_buf      */
    uint8_t  done       = 0;            /* END marker received           */

    memset(window,  0xFF, LZSS_WINDOW_SIZE);
    memset(out_buf, 0xFF, LZSS_OUT_BUF);

    /* ---- Helper: get next compressed byte from chunk protocol ---- */
    /* We use a local lambda-style approach via inline logic below     */

    while (total < original_size)
    {
        /* --- Refill bit buffer --- */
        if (bit_pos == 0)
        {
            /* Need 1 more compressed byte — get it from chunk protocol */
            while (chunk_pos >= chunk_len)
            {
                if (done) return (total == original_size) ? 1 : 0;

                /* Read 2-byte size header */
                uint8_t size_buf[2];
                UART_ReadExact(huart, size_buf, 2);
                uint16_t size = size_buf[0] | (size_buf[1] << 8);

                /* END marker */
                if (size == END_MARKER)
                {
                    HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
                    done = 1;
                    break;
                }

                /* Invalid chunk size */
                if (size > MAX_CHUNK)
                {
                    HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
                    continue;
                }

                /* ACK before data */
                HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);

                /* Read chunk data */
                UART_ReadExact(huart, chunk_buf, size);
                chunk_len = size;
                chunk_pos = 0;

                /* ACK after data */
                HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
            }

            if (done && chunk_pos >= chunk_len) break;

            bit_buf = chunk_buf[chunk_pos++];
            bit_pos = 8;
        }

        /* --- Read 1 flag bit MSB first --- */
        uint8_t flag = (bit_buf >> 7) & 1;
        bit_buf      = (bit_buf << 1) & 0xFF;
        bit_pos--;

        if (flag == 0)
        {
            /* ---- LITERAL ---- */
            /* Need 1 byte from chunk */
            while (chunk_pos >= chunk_len)
            {
                if (done) return 0;

                uint8_t size_buf[2];
                UART_ReadExact(huart, size_buf, 2);
                uint16_t size = size_buf[0] | (size_buf[1] << 8);

                if (size == END_MARKER)
                {
                    HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
                    done = 1;
                    break;
                }
                if (size > MAX_CHUNK) continue;

                HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
                UART_ReadExact(huart, chunk_buf, size);
                chunk_len = size;
                chunk_pos = 0;
                HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
            }
            if (done && chunk_pos >= chunk_len) break;

            uint8_t byte        = chunk_buf[chunk_pos++];
            window[win_pos]     = byte;
            out_buf[out_pos++]  = byte;
            win_pos             = (win_pos + 1) % LZSS_WINDOW_SIZE;
            total++;
        }
        else
        {
            /* ---- BACK-REFERENCE: need 2 bytes ---- */
            uint8_t ref_bytes[2];
            for (uint8_t rb = 0; rb < 2; rb++)
            {
                while (chunk_pos >= chunk_len)
                {
                    if (done) return 0;

                    uint8_t size_buf[2];
                    UART_ReadExact(huart, size_buf, 2);
                    uint16_t size = size_buf[0] | (size_buf[1] << 8);

                    if (size == END_MARKER)
                    {
                        HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
                        done = 1;
                        break;
                    }
                    if (size > MAX_CHUNK) continue;

                    HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
                    UART_ReadExact(huart, chunk_buf, size);
                    chunk_len = size;
                    chunk_pos = 0;
                    HAL_UART_Transmit(huart, (uint8_t*)&ACK_BYTE, 1, HAL_MAX_DELAY);
                }
                if (done && chunk_pos >= chunk_len) return 0;
                ref_bytes[rb] = chunk_buf[chunk_pos++];
            }

            uint32_t offset = (uint32_t)ref_bytes[0] + 1;
            uint32_t length = (uint32_t)ref_bytes[1] + LZSS_MIN_MATCH;

            for (uint32_t k = 0; k < length && total < original_size; k++)
            {
                uint32_t src_pos   = (win_pos - offset + LZSS_WINDOW_SIZE)
                                      % LZSS_WINDOW_SIZE;
                uint8_t  byte      = window[src_pos];
                window[win_pos]    = byte;
                out_buf[out_pos++] = byte;
                win_pos            = (win_pos + 1) % LZSS_WINDOW_SIZE;
                total++;

                /* Flush out_buf to flash when full */
                if (out_pos == LZSS_OUT_BUF)
                {
                    uint32_t aligned = (out_pos + 3U) & ~3U;
                    if (Flash_Write(flash_address, out_buf, aligned) != FLASH_OK)
                        return 0;
                    flash_address += aligned;
                    out_pos        = 0;
                    memset(out_buf, 0xFF, LZSS_OUT_BUF);
                }
            }
            continue;
        }

        /* Flush out_buf to flash when full (literal path) */
        if (out_pos == LZSS_OUT_BUF)
        {
            uint32_t aligned = (out_pos + 3U) & ~3U;
            if (Flash_Write(flash_address, out_buf, aligned) != FLASH_OK)
                return 0;
            flash_address += aligned;
            out_pos        = 0;
            memset(out_buf, 0xFF, LZSS_OUT_BUF);
        }
    }

    /* Flush remaining bytes */
    if (out_pos > 0)
    {
        uint32_t aligned = (out_pos + 3U) & ~3U;
        if (Flash_Write(flash_address, out_buf, aligned) != FLASH_OK)
            return 0;
    }

    return (total == original_size) ? 1 : 0;
}
